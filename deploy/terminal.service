[Unit]
Description=Terminal for Princess Evelyn
After=network.target

[Service]
User=evelyn
Group=www-data
WorkingDirectory=/home/evelyn/diff-editor-terminal
Environment="PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/home/evelyn/.local/bin"
ExecStart=/usr/local/bin/gunicorn --config /home/evelyn/diff-editor-terminal/gunicorn_terminal.conf.py wsgi_terminal:app
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
