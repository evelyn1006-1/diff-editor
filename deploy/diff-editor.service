[Unit]
Description=Diff Editor for Princess Evelyn
After=network.target

[Service]
User=evelyn
Group=www-data
WorkingDirectory=/home/evelyn/diff-editor
ExecStart=/usr/local/bin/gunicorn --config /home/evelyn/diff-editor/gunicorn.conf.py wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
